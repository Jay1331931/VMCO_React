{
  "appId": "com.vmco.android.talabpoint",
  "appName": "Talabpoint",
  "bundledWebRuntime": false,
  "npmClient": "npm",
  "webDir": "build",

  "plugins": {
    "Keyboard": {
      "resize": "none",
      "resizeOnFullScreen": false,
      "hideFormAccessoryBar": true,
      "keyboardDisplayRequiresUserAction": true
    }
  },
  "server": {
    "url":"https://talabpoint.com",
    "errorPath": "offline.html",
    "androidScheme": "https",
    "allowNavigation": [
      "*.azurewebsites.net"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true
  }
}