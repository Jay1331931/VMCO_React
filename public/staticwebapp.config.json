{
  "routes": [
    {
      "route": "/static/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "headers": {
        "Content-Type": "text/html"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/static/*", "/*.css", "/*.js", "/*.json"]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".css": "text/css",
    ".json": "application/json"
  },
  "platform": {
    "apiLocation": "api",
    "appLocation": "build",
    "outputLocation": ".",
    "environment": "production"
  }
}